    "This will reset all city lists back to their defaults. Any cities you added or removed will be lost.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle Städtelisten auf die Standardwerte zurückgesetzt. Alle hinzugefügten oder entfernten Städte gehen verloren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto restablecerá todas las listas de ciudades a sus valores predeterminados. Se perderán las ciudades añadidas o eliminadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toutes les listes de villes seront réinitialisées. Les villes ajoutées ou supprimées seront perdues."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti gli elenchi di città verranno ripristinati ai valori predefiniti. Le città aggiunte o rimosse andranno perse."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての都市リストをデフォルトに戻します。追加または削除した都市は失われます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 도시 목록이 기본값으로 재설정됩니다. 추가하거나 제거한 도시는 사라집니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto repõe todas as listas de cidades para os valores predefinidos. As cidades adicionadas ou removidas serão perdidas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все списки городов будут сброшены к значениям по умолчанию. Добавленные или удаленные города будут потеряны."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会将所有城市列表重置为默认值。你添加或移除的城市将会丢失。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會將所有城市列表重置為預設值。你加入或移除的城市將會遺失。"
          }
        }
      }
    },
